# Stage-1 VPS Instanz fuer die Kundenanwendung unter lies.easybrainlab.com

PORT=3001
NODE_ENV=production
DB_CLIENT=postgres

ADMIN_USERNAME=admin
ADMIN_PASSWORD=BITTE_STARKES_ADMIN_PASSWORT_SETZEN
ADMIN_EMAIL=admin@easybrainlab.com

SESSION_SECRET=BITTE_LANGEN_ZUFAELLIGEN_SESSION_SECRET_SETZEN
ENCRYPTION_KEY=BITTE_LANGEN_ZUFAELLIGEN_ENCRYPTION_KEY_SETZEN

FRONTEND_URL=https://lies.easybrainlab.com
PUBLIC_DOMAIN=lies.easybrainlab.com
TRAEFIK_CERTRESOLVER=cloudflare
