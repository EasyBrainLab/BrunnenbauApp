# Server
PORT=3001
# WICHTIG: In Produktion auf "production" setzen!
NODE_ENV=development

# Admin-Zugang
# WICHTIG: In Produktion ein sicheres Passwort setzen! Das Standard-Passwort ist oeffentlich bekannt.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=brunnen2024!

# Session Secret
# WICHTIG: In Produktion einen langen, zufaelligen String verwenden (mind. 64 Zeichen)!
# Generieren z.B. mit: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=ein-sicherer-zufaelliger-string-hier-aendern

# SMTP E-Mail-Konfiguration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@ihr-brunnenbau.de
SMTP_PASS=ihr-email-passwort

# Absender und Empfaenger
EMAIL_FROM=info@ihr-brunnenbau.de
EMAIL_COMPANY=anfragen@ihr-brunnenbau.de

# Admin-E-Mail (fuer Passwort-Reset)
ADMIN_EMAIL=admin@ihr-brunnenbau.de

# Frontend URL (fuer CORS - in Produktion die echte Domain setzen!)
# Bei Docker-Compose lokal typischerweise http://localhost:8080
FRONTEND_URL=http://localhost:8080
FRONTEND_URLS=

# Datenbankmodus
# postgres = empfohlener Standard fuer neue Stage-1-Installationen
# sqlite = nur noch fuer Legacy-/Uebergangsinstallationen
DB_CLIENT=postgres

# Postgres-Verbindung
# Lokal ohne Docker z.B. localhost:5432, in Docker-Compose intern postgres:5432
POSTGRES_DB=brunnenbau
POSTGRES_USER=brunnenbau
POSTGRES_PASSWORD=bitte-sicheres-passwort-setzen
DATABASE_URL=postgresql://brunnenbau:bitte-sicheres-passwort-setzen@localhost:5432/brunnenbau

# Oeffentliche Basis-Domains fuer Tenant-Aufloesung per Subdomain
# Beispiel: app.easybrainlab.com, kunden.easybrainlab.com
PUBLIC_BASE_DOMAINS=

# Verschluesselungs-Key fuer API-Keys und SMTP-Passwoerter (mind. 32 Zeichen)
# Generieren z.B. mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=ein-sicherer-verschluesselungs-key-hier-aendern

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
