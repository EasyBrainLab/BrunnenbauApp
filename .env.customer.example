# Kundeninstanz (Dedicated – SQLite)
# Kopieren nach .env und alle Werte anpassen.

# Server
PORT=3001
NODE_ENV=production
DB_CLIENT=sqlite

# Admin-Zugang (beim ersten Start relevant)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=bitte-ein-langes-admin-passwort-setzen
ADMIN_EMAIL=admin@kunde.de

# Sicherheits-Secrets (je 32+ zufaellige Zeichen, z.B. via: openssl rand -hex 32)
SESSION_SECRET=bitte-einen-langen-zufaelligen-session-secret-setzen
ENCRYPTION_KEY=bitte-einen-langen-zufaelligen-encryption-key-setzen

# Domain (ohne abschliessenden Slash)
FRONTEND_URL=https://konfigurator.kunde.de
PUBLIC_DOMAIN=konfigurator.kunde.de

# SMTP (E-Mail-Versand fuer Kundenanfragen und Angebote)
SMTP_HOST=smtp.kunde.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@kunde.de
SMTP_PASS=bitte-smtp-passwort-setzen
EMAIL_FROM=info@kunde.de
EMAIL_COMPANY=anfragen@kunde.de

# Optional: Telegram-Benachrichtigungen
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
