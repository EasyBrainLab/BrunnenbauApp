# Stage-1 Kundeninstanz
# Diese Vorlage ist fuer eine dedizierte Instanz pro Kunde gedacht.

# Server
PORT=3001
NODE_ENV=production
DB_CLIENT=postgres

# Admin-Zugang
ADMIN_USERNAME=admin
ADMIN_PASSWORD=bitte-ein-langes-admin-passwort-setzen
ADMIN_EMAIL=admin@kunde.de

# Session / Verschluesselung
SESSION_SECRET=bitte-einen-langen-zufaelligen-session-secret-setzen
ENCRYPTION_KEY=bitte-einen-langen-zufaelligen-encryption-key-setzen

# Frontend / Domain
FRONTEND_URL=https://konfigurator.kunde.de
PUBLIC_DOMAIN=konfigurator.kunde.de
TRAEFIK_CERTRESOLVER=cloudflare
FRONTEND_URLS=
PUBLIC_BASE_DOMAINS=

# Postgres
POSTGRES_DB=brunnenbau
POSTGRES_USER=brunnenbau
POSTGRES_PASSWORD=bitte-ein-sicheres-postgres-passwort-setzen

# WICHTIG:
# In Docker-Compose muss das Backend intern den Hostnamen "postgres" erreichen.
DATABASE_URL=postgresql://brunnenbau:bitte-ein-sicheres-postgres-passwort-setzen@postgres:5432/brunnenbau

# SMTP
SMTP_HOST=smtp.kunde.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@kunde.de
SMTP_PASS=bitte-smtp-passwort-setzen
EMAIL_FROM=info@kunde.de
EMAIL_COMPANY=anfragen@kunde.de

# Optional
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
